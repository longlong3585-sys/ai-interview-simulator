# DeepSeek API 配置（必填）
DEEPSEEK_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 数据库连接（默认 SQLite，生产环境可用 PostgreSQL）
# DATABASE_URL=sqlite:///./interview.db
# DATABASE_URL=postgresql://user:password@localhost:5432/interview_db
DATABASE_URL=sqlite:///./interview.db

# JWT 密钥（生产环境请随机生成 64 位以上字符串）
SECRET_KEY=change-this-to-a-random-string-at-least-64-chars

# 简历问题生成模式（默认硬编码，设为 "ai" 则使用 DeepSeek 动态生成）
# RESUME_QUESTION_MODE=ai
